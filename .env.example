# ── Core ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
PROOFSOURCE_API_KEY=dev_key

# ── Payments ─────────────────────────────────────────
# Leave PAYMENT_MODE unset to auto-select: arc_testnet when Circle creds exist, else mock.
# PAYMENT_MODE=arc_testnet
DATABASE_URL=postgresql://proofsource:proofsource@localhost:5432/proofsource

# ── Circle Gateway / x402 / Arc (real settlement) ────
# SDK: @circle-fin/x402-batching + @x402/core (+ @x402/express seller, viem)
CIRCLE_API_KEY=
CIRCLE_GATEWAY_URL=https://gateway.circle.com   # use the testnet base URL from Circle docs
PLATFORM_WALLET_ADDRESS=
AGENT_PRIVATE_KEY=                                # buyer wallet (USDC deposited into Gateway)
SELLER_BASE_URL=http://localhost:4021            # creator x402 endpoint base (arc mode)
ARC_TESTNET_RPC_URL=
ARC_TESTNET_CHAIN_ID=
ARC_X402_NETWORK=eip155:                          # eip155:<ARC_TESTNET_CHAIN_ID>

# ── LLM (optional; relevance + answer only, never settlement) ──
LLM_ENABLED=false
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
